menu "Cheapino custom"

config CHEAPINO_DISPLAY_ON_LAYER
    bool "Keep display blanked except when a specific layer is active"
    depends on ZMK_DISPLAY
    default n
    help
      When enabled, the display is blanked at boot and stays off while
      typing. Activating the layer defined in CHEAPINO_DISPLAY_ON_LAYER_NUM
      wakes the display. Leaving the layer schedules a re-blank after
      CHEAPINO_DISPLAY_OFF_DELAY_MS milliseconds.

if CHEAPINO_DISPLAY_ON_LAYER

config CHEAPINO_DISPLAY_ON_LAYER_NUM
    int "Layer index that wakes the display"
    default 7

config CHEAPINO_DISPLAY_OFF_DELAY_MS
    int "Milliseconds to keep display on after leaving the layer"
    default 30000

endif # CHEAPINO_DISPLAY_ON_LAYER

endmenu
