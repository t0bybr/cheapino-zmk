#include "cheapinov2.dtsi"

/* Re-enable the on-board LED at P0.15 (physically red on Supermini clones) and
 * expose it as `indicator-led` for BlueDrink9/zmk-poor-mans-led-indicator.
 * Blinks on BT profile switch, battery boot, etc.
 */
&blue_led {
    status = "okay";
};

/ {
    aliases {
        indicator-led = &blue_led;
    };
};
